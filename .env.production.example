APP_NAME="KIM Rx"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example
APP_VERSION=v1.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kimrx
DB_USERNAME=kimrx_user
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="support@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

EFRIS_TRANSPORT=simulate
EFRIS_BATCH_LIMIT=25
EFRIS_TIMEOUT_SECONDS=20
EFRIS_CONNECT_TIMEOUT_SECONDS=10

SUPPORT_COMPANY_NAME="KIM SOFTWARE SYSTEMS"
SUPPORT_CONTACT_PERSON=
SUPPORT_PHONE_PRIMARY=
SUPPORT_PHONE_SECONDARY=
SUPPORT_EMAIL=
SUPPORT_WHATSAPP=
SUPPORT_WEBSITE=
SUPPORT_HOURS="Monday - Saturday, 8:00 AM - 6:00 PM"
SUPPORT_RESPONSE_NOTE="Share the screen, branch, error message, and time the issue happened so support can help faster."

PLATFORM_BACKUPS_AUTO_ENABLED=true
PLATFORM_BACKUPS_AUTO_TIME=02:00
PLATFORM_BACKUPS_RETENTION_COUNT=14
PLATFORM_BACKUPS_SKIP_IF_RECENT_MINUTES=240

VITE_APP_NAME="${APP_NAME}"
