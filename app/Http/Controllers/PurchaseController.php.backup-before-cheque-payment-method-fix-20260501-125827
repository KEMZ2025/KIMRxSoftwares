    public function storeReceive(Request $request, Purchase $purchase)
    {
        $user = Auth::user();
        $this->ensurePurchaseAccess($purchase, $user);

        $purchase->load('items');

        $validated = $request->validate([
            'received_quantity' => ['required', 'array'],
            'received_quantity.*' => ['nullable', 'numeric', 'min:0'],
        ]);

        DB::beginTransaction();

        try {
            foreach ($purchase->items as $index => $item) {
                $receivedNow = (float) ($validated['received_quantity'][$index] ?? 0);

                if ($receivedNow <= 0) {
                    continue;
                }

                if ($receivedNow > (float) $item->remaining_quantity) {
                    DB::rollBack();
                    return back()
                        ->withErrors(['received_quantity.' . $index => 'Received quantity cannot be greater than remaining quantity.'])
                        ->withInput();
                }

                $item->received_quantity = (float) $item->received_quantity + $receivedNow;
                $item->remaining_quantity = max(0, (float) $item->remaining_quantity - $receivedNow);

                if ((float) $item->remaining_quantity <= 0) {
                    $item->remaining_quantity = 0;
                    $item->line_status = 'fully_received';
                } elseif ((float) $item->received_quantity > 0) {
                    $item->line_status = 'partial_received';
                } else {
                    $item->line_status = 'pending';
                }

                $item->quantity = $item->received_quantity;
                $item->save();

                $batch = ProductBatch::create([
                    'client_id' => $user->client_id,
                    'branch_id' => $user->branch_id,
                    'product_id' => $item->product_id,
                    'purchase_item_id' => $item->id,
                    'supplier_id' => $purchase->supplier_id,
                    'batch_number' => $item->batch_number,
                    'expiry_date' => $item->expiry_date,
                    'purchase_price' => $item->unit_cost,
                    'retail_price' => $item->retail_price,
                    'wholesale_price' => $item->wholesale_price,
                    'quantity_received' => $receivedNow,
                    'quantity_available' => $receivedNow,
                    'reserved_quantity' => 0,
                    'is_active' => true,
                ]);

                $currentBalance = ProductBatch::where('product_id', $item->product_id)
                    ->where('client_id', $user->client_id)
                    ->where('branch_id', $user->branch_id)
                    ->sum('quantity_available');

                StockMovement::create([
                    'client_id' => $user->client_id,
                    'branch_id' => $user->branch_id,
                    'product_id' => $item->product_id,
                    'product_batch_id' => $batch->id,
                    'movement_type' => 'purchase_in',
                    'reference_type' => 'purchase',
                    'reference_id' => $purchase->id,
                    'quantity_in' => $receivedNow,
                    'quantity_out' => 0,
                    'balance_after' => $currentBalance,
                    'note' => 'Additional stock received for invoice ' . $purchase->invoice_number,
                    'created_by' => $user->id,
                ]);

                Product::where('client_id', $user->client_id)
                    ->where('id', $item->product_id)
                    ->update([
                        'purchase_price' => $item->unit_cost,
                        'retail_price' => $item->retail_price,
                        'wholesale_price' => $item->wholesale_price,
                    ]);
            }

            $purchase->refresh();
            $purchase->load('items');

            if ($purchase->items->every(fn ($i) => (float) $i->remaining_quantity == 0)) {
                $purchase->invoice_status = 'fully_received';
            } elseif ($purchase->items->some(fn ($i) => (float) $i->received_quantity > 0)) {
                $purchase->invoice_status = 'partial_received';
            } else {
                $purchase->invoice_status = 'draft';
            }

            $purchase->save();

            DB::commit();

            return redirect()
                ->route('purchases.show', $purchase->id)
                ->with('success', 'Items received successfully.');
        } catch (\Throwable $e) {
            DB::rollBack();
            throw $e;
        }
    }

    public function productPurchaseData(Product $product)
    {
        $user = Auth::user();

        if ($product->client_id != $user->client_id) {
            abort(403, 'Unauthorized access to this product.');
        }

        $oldStock = ProductBatch::where('client_id', $user->client_id)
            ->where('branch_id', $user->branch_id)
            ->where('product_id', $product->id)
            ->sum('quantity_available');

        $latestPurchasePrice = ProductBatch::where('client_id', $user->client_id)
            ->where('branch_id', $user->branch_id)
            ->where('product_id', $product->id)
            ->latest('created_at')
            ->value('purchase_price');

        $latestPurchasePrice = $latestPurchasePrice === null
            ? (float) $product->purchase_price
            : (float) $latestPurchasePrice;

        return response()->json([
            'last_purchase_price' => $latestPurchasePrice,
            'retail_price' => (float) $product->retail_price,
            'wholesale_price' => (float) $product->wholesale_price,
            'old_stock' => (float) $oldStock,
            'track_expiry' => (bool) $product->track_expiry,
            'expiry_alert_days' => $product->track_expiry ? (int) ($product->expiry_alert_days ?? 90) : 0,
            'edit_url' => route('products.edit', $product),
        ]);
    }

